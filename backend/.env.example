# Server Configuration
PORT=5000
NODE_ENV=development

# ============================================
# GROQ Configuration (All AI Agents)
# ============================================
GROQ_API_KEY=your_groq_api_key_here
AI_MODEL=llama-3.3-70b-versatile
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1200

# ============================================
# Optional: Logging Configuration
# ============================================
LOG_LEVEL=info
DEBUG=false
