# Server Configuration
PORT=5000
NODE_ENV=development

# ============================================
# GROQ Configuration (All AI Agents)
# ============================================
GROQ_API_KEY=GROQ_API_KEY=your_groq_api_key_here
AI_MODEL=llama-3.3-70b-versatile
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1200

# ============================================
# Gemini Configuration (Research Agent)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# ============================================
# GitHub Models (Azure AI Inference)
# ============================================

GITHUB_TOKEN=your_github_token_here
AZURE_ENDPOINT=https://models.inference.ai.azure.com
PHI_MODEL=Phi-4

# ============================================
# Optional: Logging Configuration
# ============================================
LOG_LEVEL=info
DEBUG=false
MOCK_LLM=true

# ============================================
# Security Configuration
# ============================================
# Comma-separated list of valid client API keys for authentication.
# Leave empty to disable auth in development. MUST be set in production.
NODE_ENV=development
CLIENT_API_KEYS=*
# Frontend origin URL for CORS restriction. Set to your production frontend URL.
FRONTEND_URL=http://localhost:5173
# Set to "true" only if behind a reverse proxy (Render, Heroku, Nginx).
TRUST_PROXY=false
