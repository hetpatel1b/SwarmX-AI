# ============================================
# SwarmX-AI Frontend Environment Configuration
# ============================================
# Copy this file to .env and update the values.
#
# All VITE_ prefixed variables are embedded in the client
# bundle at build time. Do NOT put secrets here.
# ============================================

# Application metadata
VITE_APP_NAME=SwarmX AI
VITE_APP_ENV=development

# Backend API URL
VITE_API_BASE_URL=http://localhost:5000

# Feature flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_VOICE_INPUT=false
VITE_ENABLE_EXPORTS=true
VITE_ENABLE_SWARM_ANIMATION=true

# Theme
VITE_DEFAULT_THEME=dark
