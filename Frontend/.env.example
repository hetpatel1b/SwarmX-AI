# SwarmX AI frontend runtime configuration example.
# Copy this file to .env for local development.

# Public application name displayed throughout the frontend.
VITE_APP_NAME=SwarmX AI

# Current frontend runtime environment.
# Allowed values: development, production, test
VITE_APP_ENV=development

# Backend API base URL used by Axios for all /health and /api/* requests.
# Development: http://localhost:5000
# Production Render backend: https://swarmx-ai.onrender.com
VITE_API_BASE_URL=http://localhost:5000

# Enables analytics dashboard calculations and telemetry-style UI.
# Allowed values: true, false
VITE_ENABLE_ANALYTICS=true

# Enables voice input feature gates for future workspace controls.
# Allowed values: true, false
VITE_ENABLE_VOICE_INPUT=true

# Enables PDF and PPT export actions in the Presentation Builder.
# Allowed values: true, false
VITE_ENABLE_EXPORTS=true

# Enables the visible multi-agent swarm animation sequence.
# Allowed values: true, false
VITE_ENABLE_SWARM_ANIMATION=true

# Default UI theme.
# Allowed values: dark, light, system
VITE_DEFAULT_THEME=dark
